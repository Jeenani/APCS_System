APP_MODE=production
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=<DB_PASSWORD>
DB_NAME=asutp_tasks
DB_SSLMODE=disable
SERVER_PORT=8080
JWT_SECRET=<JWT_SECRET>=<JWT_SECRET>_min_32_chars

# Для Gmail SMTP EMAIL_FROM должен быть реальным Gmail-адресом (не noreply!)
EMAIL_FROM=your_real_gmail@gmail.com

# SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_USER и EMAIL_FROM должны совпадать для Gmail
SMTP_USER=your_real_gmail@gmail.com
# Пароль приложения Gmail (не обычный пароль!)
# Создать: https://myaccount.google.com/apppasswords
SMTP_PASS=<SMTP_PASS>=<GMAIL_APP_PASSWORD>
